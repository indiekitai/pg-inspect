{
  "name": "@indiekitai/pg-inspect",
  "version": "0.1.0",
  "description": "PostgreSQL schema inspector - TypeScript port of schemainspect",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pg-inspect": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/indiekitai/pg-inspect"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "src/sql"
  ],
  "keywords": [
    "postgresql",
    "postgres",
    "schema",
    "inspect",
    "introspect",
    "database",
    "migration",
    "ddl",
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "schemainspect",
    "pg",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "pg": "^8.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
